# ============================================================
# June AI 生产环境配置
# ============================================================
# 复制此文件为 .env 后启动：cp .env.example .env
# 生产模式会强制校验必填项，缺少则启动失败。
# ============================================================

# ---- 运行模式 ----
JUNE_ENV=production
JUNE_DEBUG=false

# ---- DeepSeek API（必填） ----
# 从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ---- 安全配置（必填） ----
# API Token: 至少 16 字符，用于保护所有 /api/ 接口
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
JUNE_API_TOKEN=change-me-to-a-random-string-at-least-32-chars

# ---- 数据库 ----
# SQLite 数据库文件路径，留空使用默认 backend/june.db
# JUNE_DB_PATH=/data/june.db

# ---- 服务端口 ----
# SERVER_PORT=8000
